{
  "expo": {
    "name": "SolApp",
    "slug": "solapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appicon.png",
    "scheme": "solapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/appicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/not.png",
      "bundleIdentifier": "com.arome.dev.solapp",
      "associatedDomains": ["applinks:solapp.app"]
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appicon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode":"pan",
      "package": "com.arome.dev.solapp",
      "notification": {
        "icon": "./assets/images/not.png",
        "color": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "solapp.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "solapp"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/appicon.png"
    },
    "plugins": [
      "expo-router", 
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/not.png",
          "color": "#ffffff",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "56fdee7f-b519-4073-82f5-a101986d5c31"
      }
    }
  }
}